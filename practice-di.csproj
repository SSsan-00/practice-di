<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- コード分析ルールの適用レベル -->
    <AnalysisLevel>latest</AnalysisLevel>

    <!-- IDE系のコードスタイルルールもビルド時に反映 -->
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
  </PropertyGroup>

  <ItemGroup>
    <!-- 配下のテストプロジェクトを親プロジェクトのコンパイル対象から除外 -->
    <Compile Remove="practice-di.Tests/**/*.cs" />
    <EmbeddedResource Remove="practice-di.Tests/**/*.resx" />
    <None Remove="practice-di.Tests/**/*" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.6" />
  </ItemGroup>

</Project>
